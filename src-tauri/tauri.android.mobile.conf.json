{
    "productName":  "Popcorn Mobile",
    "version": "1.0.5",
    "identifier":  "com.popcorn.client.mobile",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build:tauri",
                  "devUrl":  "http://localhost:4326",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "Popcorn Mobile",
                                    "width":  400,
                                    "height":  800,
                                    "fullscreen":  false
                                }
                            ],
                "withGlobalTauri":  true,
                "security":  {
                                 "csp":  null,
                                 "capabilities":  ["main", "mobile"]
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png"
                            ],
                   "resources":  [
                                 ],
                   "externalBin":  [
                                   ],
                   "copyright":  "",
                   "category":  "Utility",
                   "shortDescription":  "Client l\u00e9ger Popcorn pour Android Mobile",
                   "longDescription":  "Client l\u00e9ger pour Android Mobile - se connecte au serveur Popcorn distant",
                   "android":  {
                                   "versionCode": 5,
                                   "autoIncrementVersionCode":  false
                               }
               },
    "plugins":  {
                }
}
