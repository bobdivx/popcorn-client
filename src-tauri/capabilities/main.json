{
  "identifier": "main",
  "description": "Permissions principales (core + HTTP) pour l'app.",
  "remote": { "urls": ["http://tauri.localhost/*"] },
  "windows": ["main"],
  "permissions": [
    "core:default",
    "custom-commands",
    {
      "identifier": "core:allow-invoke",
      "allow": [
        { "name": "native-fetch" },
        { "name": "get-platform" },
        { "name": "log-message" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*/*" },
        { "url": "https://*/*" }
      ]
    }
  ]
}

