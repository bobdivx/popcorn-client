{
  "productName": "Popcorn",
  "version": "1.1.0",
  "identifier": "com.popcorn.client.ios",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri",
    "devUrl": "http://localhost:4326",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": [
        "main",
        "mobile"
      ]
    }
  },
  "bundle": {
    "active": true,
    "iOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
