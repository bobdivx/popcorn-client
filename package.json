{
  "name": "popcorn-vercel",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-version.js",
    "dev": "astro dev --port 4326 --host",
    "dev:clean": "node -e \"const fs=require('fs'); try { fs.rmSync('node_modules/.vite', { recursive: true, force: true }); } catch(e) {}\" && npm run dev",
    "start": "astro dev --port 4326 --host",
    "prebuild": "node scripts/copy-version.js",
    "build": "astro build",
    "build:tauri": "node scripts/build-tauri.js",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "astro": "astro",
    "tauri": "tauri",
    "tauri:dev": "cross-env TAURI_PLATFORM=desktop tauri dev",
    "tauri:build": "cross-env TAURI_PLATFORM=desktop tauri build",
    "tauri:build:windows": "cross-env TAURI_PLATFORM=desktop tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:android": "cross-env TAURI_PLATFORM=android tauri android build --ci -t aarch64 --apk",
    "tauri:build:android-tv": "cross-env TAURI_PLATFORM=android tauri android build --ci -t aarch64 --apk --config src-tauri/tauri.android.conf.json",
    "tauri:build:android-unified": "cross-env TAURI_PLATFORM=android tauri android build --ci -t aarch64 -t armv7 -t x86_64 --apk --config src-tauri/tauri.android.conf.json",
    "tauri:build:android-unified:aab": "cross-env TAURI_PLATFORM=android tauri android build --ci -t aarch64 -t armv7 -t x86_64 --aab --config src-tauri/tauri.android.conf.json",
    "tauri:build:android-tv:aab": "cross-env TAURI_PLATFORM=android tauri android build --ci -t aarch64 -t armv7 -t x86_64 --aab --config src-tauri/tauri.android.conf.json",
    "android:setup": "powershell -ExecutionPolicy Bypass -File scripts/android/setup/setup.ps1",
    "android:check": "powershell -ExecutionPolicy Bypass -File scripts/android/setup/check.ps1",
    "android:build": "powershell -ExecutionPolicy Bypass -File scripts/android/build/build.ps1",
    "android:build:mobile": "powershell -ExecutionPolicy Bypass -File scripts/android/build/build.ps1 mobile",
    "android:build:tv": "powershell -ExecutionPolicy Bypass -File scripts/android/build/build.ps1 tv",
    "android:build:all": "powershell -ExecutionPolicy Bypass -File scripts/build-android-all.ps1",
    "android:build:aab": "powershell -ExecutionPolicy Bypass -File scripts/android/build/build.ps1 aab",
    "android:build:aab:mobile": "powershell -ExecutionPolicy Bypass -File scripts/android/build/build.ps1 mobile aab",
    "android:build:aab:tv": "powershell -ExecutionPolicy Bypass -File scripts/android/build/build.ps1 tv aab",
    "android:install": "powershell -ExecutionPolicy Bypass -File scripts/android/install/install.ps1",
    "android:install:mobile": "powershell -ExecutionPolicy Bypass -File scripts/android/install/install.ps1 mobile",
    "android:install:tv": "powershell -ExecutionPolicy Bypass -File scripts/android/install/install.ps1 tv",
    "android:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/android/install/uninstall.ps1",
    "android:test:communication": "powershell -ExecutionPolicy Bypass -File scripts/android/test/communication.ps1",
    "android:test:communication:mobile": "powershell -ExecutionPolicy Bypass -File scripts/android/test/communication.ps1 mobile",
    "android:test:communication:tv": "powershell -ExecutionPolicy Bypass -File scripts/android/test/communication.ps1 tv",
    "smoke:backend": "node scripts/smoke-backend.mjs --backend http://127.0.0.1:3000",
    "smoke:android:mobile": "powershell -ExecutionPolicy Bypass -File scripts/android-smoke-test.ps1 -Variant mobile -BackendUrl http://127.0.0.1:3000",
    "smoke:android:tv": "powershell -ExecutionPolicy Bypass -File scripts/android-smoke-test.ps1 -Variant tv -BackendUrl http://127.0.0.1:3000",
    "patch:android": "node scripts/patch-android-manifest.js",
    "create:tv-banner": "node scripts/create-tv-banner.js",
    "clean:github": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cleanup-artifacts.ps1",
    "clean:github:old": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cleanup-artifacts.ps1 -RetentionDays 4",
    "webos:build": "powershell -ExecutionPolicy Bypass -Command \"Set-Location (Join-Path (Split-Path (Get-Location)) 'popcorn-tauri'); .\\webos\\scripts\\build.ps1 -Native\"",
    "webos:build:demo": "powershell -ExecutionPolicy Bypass -Command \"Set-Location (Join-Path (Split-Path (Get-Location)) 'popcorn-tauri'); .\\webos\\scripts\\build.ps1 -Demo -Native\"",
    "webos:package": "powershell -ExecutionPolicy Bypass -Command \"Set-Location (Join-Path (Split-Path (Get-Location)) 'popcorn-tauri'); .\\webos\\scripts\\build.ps1 -Native -Package\"",
    "webos:package:demo": "powershell -ExecutionPolicy Bypass -Command \"Set-Location (Join-Path (Split-Path (Get-Location)) 'popcorn-tauri'); .\\webos\\scripts\\build.ps1 -Demo -Native -Package\"",
    "android:build:demo": "powershell -ExecutionPolicy Bypass -File scripts/android/build/build.ps1 -Demo",
    "android:build:demo:tv": "powershell -ExecutionPolicy Bypass -File scripts/android/build/build.ps1 -Demo tv",
    "android:build:demo:mobile": "powershell -ExecutionPolicy Bypass -File scripts/android/build/build.ps1 -Demo mobile",
    "tauri:build:ios": "cross-env TAURI_PLATFORM=ios tauri ios build --ci -c src-tauri/tauri.ios.conf.json",
    "ios:build": "cross-env TAURI_PLATFORM=ios tauri ios build --ci -c src-tauri/tauri.ios.conf.json",
    "ios:build:demo": "cross-env TAURI_PLATFORM=ios PUBLIC_DEMO_BACKEND_URL=https://popcorn-vercel.vercel.app tauri ios build --ci -c src-tauri/tauri.ios.conf.json",
    "create:keystore": "powershell -ExecutionPolicy Bypass -File scripts/create-keystore.ps1",
    "encode:keystore": "powershell -ExecutionPolicy Bypass -File scripts/encode-keystore.ps1"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.3",
    "@astrojs/tailwind": "^6.0.2",
    "@libsql/client": "^0.14.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-http": "^2.5.6",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@types/qrcode": "^1.5.6",
    "astro": "^5.17.2",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "daisyui": "^4.12.10",
    "hls.js": "^1.6.15",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.2",
    "lucide-preact": "^0.562.0",
    "preact": "^10.20.0",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/vercel": "^9.0.4",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/api": "^2.10.0",
    "@tauri-apps/cli": "^2.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "glob": "^13.0.0",
    "jsdom": "^27.4.0",
    "puppeteer-core": "^23.11.1",
    "sharp": "^0.34.5",
    "typescript": "^5.6.2",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vitest": "^4.0.17"
  }
}
