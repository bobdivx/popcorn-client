{
  "name": "popcorn-vercel",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 4326 --host",
    "start": "astro dev --port 4326 --host",
    "build": "astro build",
    "build:tauri": "node scripts/build-tauri.js",
    "preview": "astro preview",
    "astro": "astro",
    "tauri": "tauri",
    "tauri:dev": "cross-env TAURI_PLATFORM=desktop tauri dev",
    "tauri:build": "cross-env TAURI_PLATFORM=desktop tauri build",
    "tauri:build:windows": "cross-env TAURI_PLATFORM=desktop tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:android": "cross-env TAURI_PLATFORM=android tauri build --target aarch64-linux-android",
    "tauri:build:android-tv": "cross-env TAURI_PLATFORM=android tauri build --target aarch64-linux-android --config src-tauri/tauri.android.conf.json",
    "tauri:build:android-mobile": "cross-env TAURI_PLATFORM=android tauri build --target aarch64-linux-android --config src-tauri/tauri.android.mobile.conf.json",
    "android:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-android.ps1",
    "android:check": "powershell -ExecutionPolicy Bypass -File scripts/check-android.ps1"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.3",
    "@astrojs/tailwind": "^6.0.2",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "astro": "^5.16.6",
    "daisyui": "^4.12.10",
    "lucide-preact": "^0.562.0",
    "preact": "^10.20.0",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@astrojs/vercel": "^9.0.2",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/cli": "^2.9.6",
    "@types/node": "^20.14.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "glob": "^13.0.0",
    "typescript": "^5.6.2"
  }
}
