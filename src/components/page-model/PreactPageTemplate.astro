---
import Layout from '../../layouts/Layout.astro';

interface Props {
  title: string;
  pageClass?: string;
  component: any;
}

const { title, pageClass = '', component: PageComponent } = Astro.props;
---

<Layout title={title}>
  <div class={pageClass}>
    <PageComponent client:only="preact" />
  </div>
</Layout>
