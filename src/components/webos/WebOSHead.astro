---
/**
 * Éléments <head> conditionnels selon la plateforme.
 * Sur webOS (file://) : pas de Google Fonts pour éviter requêtes réseau et erreurs (-20).
 * Sur les autres plateformes : préconnexion + polices Google.
 */
const isWebOS = import.meta.env.WEBOS === 'true';
---

{!isWebOS && (
  <>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet" />
  </>
)}
