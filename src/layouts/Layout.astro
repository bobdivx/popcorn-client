---
import '../styles/global.css';
import ServerConnectionCheck from '../components/ServerConnectionCheck';
import Navbar from '../components/layout/Navbar';

interface Props {
  title?: string;
}

const { title = 'Popcorn Client' } = Astro.props;
---

<!doctype html>
<html lang="fr" data-theme="dark" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Popcorn Client - Client léger pour serveur Popcorn" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <link rel="icon" type="image/png" href="/popcorn_logo.png" />
    <link rel="apple-touch-icon" href="/popcorn_logo.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#a855f7" />
    <title>{title}</title>
    <!-- Google Fonts Inter et Roboto pour typographie audacieuse -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-[#121212] text-white flex flex-col overflow-x-hidden">
    <ServerConnectionCheck client:only="preact" />
    <Navbar client:only="preact" />
    <!-- Header (barre en haut) -->
    <main class="app-main flex-1 w-full overflow-x-hidden pt-20 sm:pt-22 md:pt-24 lg:pt-24 tv:pt-28">
      <slot />
    </main>
    <script is:inline>
      // Intercepter les routes /player/* et rediriger vers /player avec l'ID en query param
      // Cela permet de gérer les routes dynamiques en mode static
      (function() {
        if (typeof window !== 'undefined') {
          const pathname = window.location.pathname;
          const playerMatch = pathname.match(/^\/player\/(.+)$/);
          if (playerMatch && playerMatch[1]) {
            const id = playerMatch[1];
            // Rediriger vers /player avec l'ID en query param (sans recharger si déjà sur /player)
            if (!window.location.search.includes('id=') && !window.location.search.includes('contentId=')) {
              window.location.replace('/player?id=' + encodeURIComponent(id));
            }
          }
        }
      })();
    </script>
  </body>
</html>

