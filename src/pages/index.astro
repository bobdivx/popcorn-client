---
import Layout from '../layouts/Layout.astro';
import FeatureCard from '../components/FeatureCard';
---

<Layout title="Popcorn Torrent - Plateforme de Streaming Torrent">
  <div class="min-h-screen bg-black text-white">
    <!-- Hero Section -->
    <section class="container mx-auto px-4 py-16 md:py-24 text-center">
      <div class="mb-8 animate-fade-in">
        <img 
          src="/popcorn_logo.png" 
          alt="Popcorn Torrent" 
          class="w-24 h-24 md:w-32 md:h-32 object-contain mx-auto mb-8"
          loading="eager"
        />
      </div>
      <h1 class="text-4xl md:text-6xl font-bold mb-6">
        Popcorn Torrent
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto">
        Plateforme moderne de streaming torrent avec synchronisation cloud et interface intuitive
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/docs/docker/quick-start" 
          class="bg-red-600 hover:bg-red-700 text-white font-semibold px-8 py-3 rounded-lg transition-colors"
        >
          Démarrer avec Docker
        </a>
        <a 
          href="/docs" 
          class="bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-3 rounded-lg border border-white/20 transition-colors"
        >
          Documentation
        </a>
      </div>
    </section>

    <!-- Features Section -->
    <section class="container mx-auto px-4 py-16">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
        Fonctionnalités
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <FeatureCard 
          client:load
          title="Streaming Torrent"
          description="Regardez vos films et séries en streaming direct depuis les torrents, sans téléchargement préalable."
          icon="🎬"
        />
        <FeatureCard 
          client:load
          title="Indexers Multiples"
          description="Support de plusieurs indexers (Jackett, YGG, etc.) avec recherche unifiée et gestion de priorités."
          icon="🔍"
        />
        <FeatureCard 
          client:load
          title="Intégration TMDb"
          description="Enrichissement automatique avec les métadonnées TMDb : posters, synopsis, genres, et bien plus."
          icon="🎭"
        />
        <FeatureCard 
          client:load
          title="Synchronisation Cloud"
          description="Synchronisez votre configuration entre plusieurs instances via notre plateforme cloud."
          icon="☁️"
        />
        <FeatureCard 
          client:load
          title="Interface Moderne"
          description="Interface utilisateur moderne et responsive, optimisée pour la navigation TV et mobile."
          icon="📱"
        />
        <FeatureCard 
          client:load
          title="API Complète"
          description="API REST complète pour l'intégration et l'automatisation de vos workflows."
          icon="⚙️"
        />
      </div>
    </section>

    <!-- Quick Start Section -->
    <section class="container mx-auto px-4 py-16 bg-white/5">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-8">
          Démarrage Rapide
        </h2>
        <div class="bg-black/50 border border-white/10 rounded-lg p-6 mb-6">
          <pre class="text-green-400 overflow-x-auto"><code>docker-compose up -d</code></pre>
        </div>
        <p class="text-center text-gray-300 mb-8">
          C'est tout ! Votre instance Popcorn Torrent sera prête en quelques minutes.
        </p>
        <div class="text-center">
          <a 
            href="/docs/docker/quick-start" 
            class="text-red-400 hover:text-red-300 font-semibold"
          >
            Voir le guide complet →
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="container mx-auto px-4 py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Prêt à commencer ?
      </h2>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Déployez votre instance Popcorn Torrent en quelques minutes et profitez d'une expérience de streaming torrent moderne.
      </p>
      <a 
        href="/docs/docker/quick-start" 
        class="inline-block bg-red-600 hover:bg-red-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors"
      >
        Lire la Documentation
      </a>
    </section>
  </div>
</Layout>