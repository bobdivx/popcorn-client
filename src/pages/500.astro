---
import ErrorPage from '../components/errors/ErrorPage';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="fr" data-theme="dark" class="overflow-hidden">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function(){try{var s=localStorage.getItem('popcorn_client_user_preferences');var t='dark';if(s){var p=JSON.parse(s);t=p.theme||'auto';}if(t==='auto')t=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';document.documentElement.dataset.theme=t;}catch(e){}})();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Erreur serveur - Popcorn Torrent" />
    <link rel="icon" type="image/png" href="/popcorn_logo.png" />
    <title>500 - Erreur serveur - Popcornn</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
  </head>
  <body class="min-h-screen bg-black text-white overflow-hidden">
    <ErrorPage 
      client:load
      code={500}
      title="Erreur serveur"
      message="Une erreur interne s'est produite. Notre équipe a été notifiée et travaille à résoudre le problème."
      showHomeButton={true}
      showBackButton={true}
    />
  </body>
</html>
