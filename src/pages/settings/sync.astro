---
import Layout from '../../layouts/Layout.astro';
import TorrentSyncManager from '../../components/settings/TorrentSyncManager';
import PageHeader from '../../components/ui/PageHeader';
---

<Layout title="Synchronisation des Torrents - Popcorn Client">
  <div class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">
    <div class="container mx-auto px-4 sm:px-6 md:px-8 lg:px-12 py-8 sm:py-10 md:py-12">
      <PageHeader
        client:only="preact"
        title="Synchronisation"
        subtitle="Gérez la synchronisation automatique des torrents"
        backHref="/settings"
      >
        <a
          href="/settings/indexers"
          class="btn btn-ghost glass-panel hover:bg-white/10 border border-white/10 text-xs sm:text-sm md:text-base px-3 sm:px-4 md:px-6 py-2 sm:py-3 min-h-[44px] sm:min-h-[48px] focus:outline-none focus:ring-4 focus:ring-primary-600/50 transition-colors"
        >
          Configurer les indexers
        </a>
      </PageHeader>

      {/* Section Synchronisation */}
      <div class="mb-8 sm:mb-10 md:mb-12">
        <TorrentSyncManager client:only="preact" />
      </div>
    </div>
  </div>
</Layout>
