---
import SettingsLayout from '../../layouts/SettingsLayout.astro';
import MediaPathsPanel from '../../components/settings/MediaPathsPanel';
import PermissionGuard from '../../components/ui/PermissionGuard';
import DsPageHeader from '../../components/ui/DsPageHeader';
---

<SettingsLayout title="Chemins des médias - Popcorn">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="settingsMenu.mediaPaths.title"
      subtitleKey="settingsMenu.mediaPaths.description"
    />
    <PermissionGuard client:only="preact" permission="settings.server">
      <MediaPathsPanel client:only="preact" />
    </PermissionGuard>
  </div>
</SettingsLayout>
