---
import SettingsLayout from '../../layouts/SettingsLayout.astro';
import LibraryDisplaySettingsPanel from '../../components/settings/LibraryDisplaySettingsPanel';
import DsPageHeader from '../../components/ui/DsPageHeader';
---

<SettingsLayout title="Affichage de la bibliothèque - Popcorn">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="interfaceSettings.librarySection"
      subtitleKey="interfaceSettings.librarySectionDescription"
    />
    <LibraryDisplaySettingsPanel client:only="preact" />
  </div>
</SettingsLayout>
