---
import SettingsLayout from '../../layouts/SettingsLayout.astro';
import LibrarySourcesPanel from '../../components/settings/LibrarySourcesPanel';
import PermissionGuard from '../../components/ui/PermissionGuard';
import DsPageHeader from '../../components/ui/DsPageHeader';
---

<SettingsLayout title="Sources de la bibliothèque - Popcorn">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="settingsMenu.librarySources.title"
      subtitleKey="settingsMenu.librarySources.description"
    />
    <PermissionGuard client:only="preact" permission="settings.server">
      <LibrarySourcesPanel client:only="preact" />
    </PermissionGuard>
  </div>
</SettingsLayout>
