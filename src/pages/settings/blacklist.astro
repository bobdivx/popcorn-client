---
import SettingsLayout from '../../layouts/SettingsLayout.astro';
import BlacklistManager from '../../components/settings/BlacklistManager';
import DsPageHeader from '../../components/ui/DsPageHeader';
---

<SettingsLayout title="Liste noire - Popcorn">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="blacklist.title"
      subtitleKey="blacklist.description"
    />
    <BlacklistManager client:only="preact" />
  </div>
</SettingsLayout>
