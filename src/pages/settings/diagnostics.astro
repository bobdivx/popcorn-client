---
import Layout from '../../layouts/Layout.astro';
import BackendDiagnostics from '../../components/settings/BackendDiagnostics';
import TranslatedTitle from '../../components/ui/TranslatedTitle';
import PermissionGuard from '../../components/ui/PermissionGuard';
---

<Layout title="Diagnostics - Popcorn Client">
  <div class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">
    <div class="container mx-auto px-4 sm:px-6 md:px-8 lg:px-12 py-8 sm:py-10 md:py-12">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-black text-white mb-6">
        <TranslatedTitle client:only="preact" translationKey="settingsPages.diagnostics.title" />
      </h1>
      <PermissionGuard client:only="preact" permission="settings.server">
        <BackendDiagnostics client:only="preact" />
      </PermissionGuard>
    </div>
  </div>
</Layout>

