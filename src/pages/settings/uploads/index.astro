---
import SettingsLayout from '../../../layouts/SettingsLayout.astro';
import UploadsSubMenuPanel from '../../../components/settings/UploadsSubMenuPanel';
import PermissionGuard from '../../../components/ui/PermissionGuard';
import DsPageHeader from '../../../components/ui/DsPageHeader';
---

<SettingsLayout title="Uploads - Popcorn Client">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="settingsPages.uploads.title"
      subtitleKey="settingsPages.uploads.subtitle"
    />
    <PermissionGuard client:only="preact" permission="settings.indexers">
      <UploadsSubMenuPanel client:only="preact" />
    </PermissionGuard>
  </div>
</SettingsLayout>
