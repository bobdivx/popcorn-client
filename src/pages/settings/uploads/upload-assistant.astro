---
import SettingsLayout from '../../../layouts/SettingsLayout.astro';
import UploadAssistantPanel from '../../../components/settings/UploadAssistantPanel';
import PermissionGuard from '../../../components/ui/PermissionGuard';
import DsPageHeader from '../../../components/ui/DsPageHeader';
---

<SettingsLayout title="P-upload - Popcorn Client">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="settings.uploadTrackerPanel.title"
      subtitleKey="settings.uploadTrackerPanel.description"
    />
    <PermissionGuard client:only="preact" permission="settings.indexers">
      <UploadAssistantPanel client:only="preact" />
    </PermissionGuard>
  </div>
</SettingsLayout>

