---
import SettingsLayout from '../../layouts/SettingsLayout.astro';
import FeedbackChat from '../../components/settings/FeedbackChat';
import PermissionGuard from '../../components/ui/PermissionGuard';
import DsPageHeader from '../../components/ui/DsPageHeader';
---

<SettingsLayout title="Feedback - Popcorn Client">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="settingsPages.feedback.title"
      subtitleKey="settingsPages.feedback.subtitle"
    />
    <PermissionGuard client:only="preact" permission="settings.account">
      <FeedbackChat client:only="preact" />
    </PermissionGuard>
  </div>
</SettingsLayout>
