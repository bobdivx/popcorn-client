---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/ui/PageHeader';
---

<Layout title="Préférences UI - Popcorn Client">
  <div class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">
    <div class="container mx-auto px-4 sm:px-6 md:px-8 lg:px-12 py-8 sm:py-10 md:py-12">
      <PageHeader
        client:only="preact"
        title="Préférences UI"
        subtitle="Personnalisez l’interface (bientôt plus d’options)"
        backHref="/settings"
      />

      <div class="space-y-8 sm:space-y-10 md:space-y-12">
        <div class="glass-panel rounded-2xl shadow-2xl border border-white/10 p-6 sm:p-8 md:p-12">
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-white mb-6 sm:mb-8">Préférences d'interface</h2>
          <p class="text-gray-400 mb-4">Cette page permet de configurer les préférences d'interface utilisateur.</p>
          <p class="text-gray-500 text-sm">Les fonctionnalités de personnalisation (thème, langue, etc.) seront disponibles prochainement.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
