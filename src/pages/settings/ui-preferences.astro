---
import Layout from '../../layouts/Layout.astro';
import TranslatedPageHeader from '../../components/ui/TranslatedPageHeader';
import UiPreferencesPanel from '../../components/settings/UiPreferencesPanel';
import PermissionGuard from '../../components/ui/PermissionGuard';
---

<Layout title="Préférences UI - Popcorn Client">
  <div class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">
    <div class="container mx-auto px-4 sm:px-6 md:px-8 lg:px-12 py-8 sm:py-10 md:py-12">
      <TranslatedPageHeader
        client:only="preact"
        titleKey="settingsMenu.uiPreferences.title"
        subtitleKey="settingsMenu.uiPreferences.description"
        backHref="/settings"
      />

      <PermissionGuard client:only="preact" permission="settings.ui_preferences">
        <div class="glass-panel rounded-2xl shadow-2xl border border-white/10 p-6 sm:p-8 md:p-12 max-w-2xl">
          <UiPreferencesPanel client:only="preact" />
        </div>
      </PermissionGuard>
    </div>
  </div>
</Layout>
