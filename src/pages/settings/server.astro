---
import Layout from '../../layouts/Layout.astro';
import ServerSettings from '../../components/settings/ServerSettings';
import PageHeader from '../../components/ui/PageHeader';
---

<Layout title="Configuration du Serveur - Popcorn Client">
  <div class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">
    <div class="container mx-auto px-4 sm:px-6 md:px-8 lg:px-12 py-8 sm:py-10 md:py-12">
      <PageHeader
        client:only="preact"
        title="Serveur"
        subtitle="Configurez l’URL du serveur Popcorn auquel se connecter"
        backHref="/settings"
      />

      <div class="space-y-8 sm:space-y-10 md:space-y-12">
        <ServerSettings client:only="preact" />
      </div>
    </div>
  </div>
</Layout>
