---
import SettingsLayout from '../../layouts/SettingsLayout.astro';
import LocalUsersManager from '../../components/settings/LocalUsersManager';
import PermissionGuard from '../../components/ui/PermissionGuard';
import DsPageHeader from '../../components/ui/DsPageHeader';
---

<SettingsLayout title="Utilisateurs locaux - Popcorn">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="settingsMenu.localUsers.title"
      subtitleKey="settingsMenu.localUsers.description"
    />
    <PermissionGuard client:only="preact" permission="settings.local_users">
      <LocalUsersManager client:only="preact" />
    </PermissionGuard>
  </div>
</SettingsLayout>
