---
import Layout from '../../layouts/Layout.astro';
import FriendsManager from '../../components/settings/FriendsManager';
import PermissionGuard from '../../components/ui/PermissionGuard';
---

<Layout title="Friends - Popcorn">
  <div class="min-h-screen bg-[#121212] p-4 sm:p-6 md:p-8">
    <div class="max-w-6xl mx-auto">
      <PermissionGuard client:only="preact" permission="settings.friends">
        <FriendsManager client:only="preact" />
      </PermissionGuard>
    </div>
  </div>
</Layout>

