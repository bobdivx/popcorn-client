---
import SettingsLayout from '../../layouts/SettingsLayout.astro';
import DebugSyncCheck from '../../components/settings/DebugSyncCheck';
import PermissionGuard from '../../components/ui/PermissionGuard';
import DsPageHeader from '../../components/ui/DsPageHeader';
---

<SettingsLayout title="Debug Sync - Popcorn Client">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="settingsPages.debugSync.pageTitle"
      subtitleKey="settingsPages.debugSync.pageSubtitle"
    />
    <PermissionGuard client:only="preact" permission="settings.sync">
      <div class="space-y-6 sm:space-y-8">
        <DebugSyncCheck client:only="preact" />
      </div>
    </PermissionGuard>
  </div>
</SettingsLayout>
