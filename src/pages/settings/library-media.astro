---
import SettingsLayout from '../../layouts/SettingsLayout.astro';
import LibraryMediaPanel from '../../components/settings/LibraryMediaPanel';
import PermissionGuard from '../../components/ui/PermissionGuard';
import DsPageHeader from '../../components/ui/DsPageHeader';
---

<SettingsLayout title="Médias de la bibliothèque - Popcorn">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="settingsMenu.libraryMedia.title"
      subtitleKey="settingsMenu.libraryMedia.description"
    />
    <PermissionGuard client:only="preact" permission="settings.server">
      <LibraryMediaPanel client:only="preact" />
    </PermissionGuard>
  </div>
</SettingsLayout>
