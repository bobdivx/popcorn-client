---
import SettingsLayout from '../../layouts/SettingsLayout.astro';
import RequestsAdminManager from '../../components/settings/RequestsAdminManager';
import DsPageHeader from '../../components/ui/DsPageHeader';
---

<SettingsLayout title="Gestion des demandes - Popcorn">
  <div class="ds-container max-w-5xl py-4 sm:py-6 px-3 sm:px-6">
    <DsPageHeader
      client:only="preact"
      titleKey="requestsAdmin.title"
      subtitleKey="requestsAdmin.description"
    />
    <RequestsAdminManager client:only="preact" />
  </div>
</SettingsLayout>
