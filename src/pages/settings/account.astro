---
import Layout from '../../layouts/Layout.astro';
import AccountSettings from '../../components/settings/AccountSettings';
import PageHeader from '../../components/ui/PageHeader';
---

<Layout title="Mon Compte - Popcorn Client">
  <div class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">
    <div class="container mx-auto px-4 sm:px-6 md:px-8 lg:px-12 py-8 sm:py-10 md:py-12">
      <PageHeader
        client:only="preact"
        title="Mon compte"
        subtitle="Gérez votre profil (avatar/nom) et consultez vos informations"
        backHref="/settings"
      />

      <div class="space-y-8 sm:space-y-10 md:space-y-12">
        <AccountSettings client:only="preact" />
      </div>
    </div>
  </div>
</Layout>
