---
import Layout from '../layouts/Layout.astro';
import LibraryComponent from '../components/Library';
import TranslatedTitle from '../components/ui/TranslatedTitle';
---

<Layout title="Bibliothèque - Popcorn Client">
  <div class="min-h-screen bg-black text-white">
    <div class="px-3 sm:px-4 md:px-6 lg:px-8 xl:px-12 tv:px-16 pt-8 sm:pt-10 md:pt-12">
      <h1 class="text-lg sm:text-xl md:text-2xl tv:text-3xl font-bold text-white mb-2 sm:mb-3 tv:mb-4 px-3 sm:px-4 md:px-6 lg:px-8 xl:px-12 tv:px-16">
        <TranslatedTitle client:only="preact" translationKey="library.title" />
      </h1>
      <LibraryComponent client:only="preact" />
    </div>
  </div>
</Layout>
