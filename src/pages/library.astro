---
import '../styles/global.css';
import Header from '../components/Header';
import Library from '../components/Library';
---

<!doctype html>
<html lang="fr" data-theme="dark" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Ma Bibliothèque - Popcorn" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/popcorn_logo.png" />
    <title>Ma Bibliothèque - Popcorn</title>
  </head>
  <body class="min-h-screen bg-black text-white flex flex-col">
    <Header client:load />
    <main class="flex-1 container mx-auto px-4 py-8">
      <h1 class="text-3xl font-bold mb-6">Ma Bibliothèque</h1>
      <Library client:only="preact" />
    </main>
  </body>
</html>
