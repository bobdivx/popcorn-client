---
/**
 * Lanceur webOS : redirige directement vers le client cloud.
 * Pas de localStorage, pas d'écran de choix — redirection immédiate.
 */
const cloudClientUrl = typeof import.meta.env.PUBLIC_CLIENT_URL !== 'undefined' && import.meta.env.PUBLIC_CLIENT_URL
  ? String(import.meta.env.PUBLIC_CLIENT_URL).replace(/\/$/, '') + '/'
  : 'https://dev.popcornn.app/';
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Popcorn</title>
  <script define:vars={{ cloudClientUrl }} is:inline>
    window.location.replace(cloudClientUrl);
  </script>
</head>
<body></body>
</html>
