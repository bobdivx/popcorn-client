---
import Layout from '../../layouts/Layout.astro';
import DocNav from '../../components/DocNav';
---

<Layout title="Documentation - Popcorn Torrent">
  <div class="min-h-screen bg-black text-white">
    <DocNav client:load currentPath="/docs" />
    
    <div class="container mx-auto px-4 py-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Documentation
      </h1>
      <p class="text-xl text-gray-300 mb-12 max-w-3xl">
        Bienvenue dans la documentation de Popcorn Torrent. Apprenez à déployer, configurer et utiliser la plateforme.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Docker Documentation -->
        <div class="bg-white/5 border border-white/10 rounded-lg p-6 hover:bg-white/10 transition-colors">
          <h2 class="text-2xl font-bold mb-4">🐳 Docker</h2>
          <p class="text-gray-300 mb-4">
            Guides complets pour déployer Popcorn Torrent avec Docker et Docker Compose.
          </p>
          <ul class="list-disc list-inside text-gray-400 space-y-2 mb-6">
            <li><a href="/docs/docker/quick-start" class="text-red-400 hover:text-red-300">Démarrage rapide</a></li>
            <li><a href="/docs/docker" class="text-red-400 hover:text-red-300">Documentation complète</a></li>
            <li><a href="/docs/docker/advanced" class="text-red-400 hover:text-red-300">Configuration avancée</a></li>
          </ul>
          <a 
            href="/docs/docker/quick-start" 
            class="inline-block bg-red-600 hover:bg-red-700 text-white font-semibold px-4 py-2 rounded transition-colors"
          >
            Commencer →
          </a>
        </div>

        <!-- API Documentation -->
        <div class="bg-white/5 border border-white/10 rounded-lg p-6 hover:bg-white/10 transition-colors">
          <h2 class="text-2xl font-bold mb-4">⚙️ API</h2>
          <p class="text-gray-300 mb-4">
            Documentation complète de l'API REST pour l'intégration et l'automatisation.
          </p>
          <ul class="list-disc list-inside text-gray-400 space-y-2 mb-6">
            <li><a href="/docs/api" class="text-red-400 hover:text-red-300">Vue d'ensemble</a></li>
            <li><a href="/docs/api/authentication" class="text-red-400 hover:text-red-300">Authentification</a></li>
            <li><a href="/docs/api/qr-login" class="text-red-400 hover:text-red-300">Connexion QR Code</a></li>
            <li><a href="/docs/api/sync" class="text-red-400 hover:text-red-300">Synchronisation</a></li>
          </ul>
          <a 
            href="/docs/api" 
            class="inline-block bg-red-600 hover:bg-red-700 text-white font-semibold px-4 py-2 rounded transition-colors"
          >
            Explorer l'API →
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="mt-16">
        <h2 class="text-3xl font-bold mb-8">Liens rapides</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a 
            href="/docs/docker/quick-start" 
            class="bg-white/5 border border-white/10 rounded-lg p-4 hover:bg-white/10 transition-colors"
          >
            <h3 class="font-bold mb-2">🚀 Démarrage rapide</h3>
            <p class="text-sm text-gray-400">Déployez en 5 minutes</p>
          </a>
          <a 
            href="/features" 
            class="bg-white/5 border border-white/10 rounded-lg p-4 hover:bg-white/10 transition-colors"
          >
            <h3 class="font-bold mb-2">✨ Fonctionnalités</h3>
            <p class="text-sm text-gray-400">Découvrez les capacités</p>
          </a>
          <a 
            href="/docs/api" 
            class="bg-white/5 border border-white/10 rounded-lg p-4 hover:bg-white/10 transition-colors"
          >
            <h3 class="font-bold mb-2">📚 Documentation API</h3>
            <p class="text-sm text-gray-400">Intégration et automatisation</p>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>